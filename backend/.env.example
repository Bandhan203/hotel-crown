# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# python-decouple reads these from `backend/.env` when running Django.

# ──────────────────────────────────────────────
# Database (MySQL)
# ──────────────────────────────────────────────
DB_NAME=hotel_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ──────────────────────────────────────────────
# Django core
# ──────────────────────────────────────────────
# Generate a strong key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ──────────────────────────────────────────────
# Superuser (optional — for `createsuperuser --noinput`)
# Custom user model uses email as the login field.
# ──────────────────────────────────────────────
DJANGO_SUPERUSER_EMAIL=admin@hotel.local
DJANGO_SUPERUSER_FULL_NAME=Admin User
DJANGO_SUPERUSER_PASSWORD=change-me-strong-password

# ──────────────────────────────────────────────
# SSLCommerz payment gateway
# Use sandbox credentials for local development.
# ──────────────────────────────────────────────
SSLCZ_STORE_ID=testbox
SSLCZ_STORE_PASSWORD=qwerty
SSLCZ_IS_SANDBOX=True

# ──────────────────────────────────────────────
# CORS & frontend
# Comma-separated list of allowed origins (no trailing slash).
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Celery / Redis (optional — defaults shown)
# ──────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
